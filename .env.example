# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ---------- Anthropic ----------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---------- Microsoft Graph (MSAL device-code) ----------
# Azure portal > App registrations > your app > Overview > Application (client) ID
# The app must be configured for personal Microsoft accounts and have
# the Mail.Read delegated permission with "Allow public client flows" enabled.
# See README.md § Azure App Registration for step-by-step instructions.
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------- Google Sheets ----------
# Absolute (or relative) path to your service account JSON key file.
# The file itself is gitignored; only this path lives in .env.
# The service account email must be granted Editor access to your spreadsheet.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Google Sheets spreadsheet ID — the long string in the sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your-spreadsheet-id-here
